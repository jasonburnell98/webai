VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Clerk Authentication — https://clerk.com (free tier available)
# 1. Create an account and a new application at https://dashboard.clerk.com
# 2. Enable the auth methods you want (Email/Password, Google, GitHub, etc.)
# 3. Copy your Publishable Key from API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase — used only for database (conversations, messages, user profiles)
# Auth is handled by Clerk; Supabase Auth is NOT used.
# IMPORTANT: Run supabase/schema.sql against your project before starting.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe (optional — for Pro subscriptions)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
